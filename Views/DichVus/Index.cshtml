@model IEnumerable<SPASMART.Models.DichVuSanPham>

@{
    ViewData["Title"] = "Dịch vụ spa";
}

<div class="spa-page">
    <div class="spa-header">
        <small>USER SITE</small>
        <h1>Dịch vụ chăm sóc tại SpaSmart</h1>
        <p>
            Khách hàng có thể xem danh sách dịch vụ chăm sóc da, massage, trị liệu và thư giãn tại SpaSmart.
        </p>
    </div>

    <div class="spa-toolbar">
        <form asp-action="Index" method="get" class="spa-search">
            <input type="text" name="keyword" value="@ViewBag.Keyword" placeholder="Tìm dịch vụ..." />
            <button type="submit" class="btn-light-spa">Tìm kiếm</button>
        </form>
    </div>

    <div class="user-service-grid">
        @foreach (var item in Model)
        {
            <div class="user-service-card">
                @if (!string.IsNullOrEmpty(item.HinhAnh))
                {
                    <img src="@item.HinhAnh" />
                }
                else
                {
                    <div class="user-service-empty-img"></div>
                }

                <div class="user-service-content">
                    <span>Dịch vụ spa</span>
                    <h3>@item.TenDVSP</h3>
                    <p>@item.MoTa</p>

                    <div class="user-service-meta">
                        <strong>@item.Gia.ToString("N0") đ</strong>
                        <small>
                            @(item.ThoiLuong.HasValue? item.ThoiLuong + " phút" : "Đang cập nhật")
                        </small>
                    </div>

                    <a asp-action="Details" asp-route-id="@item.MaDVSP" class="btn-light-spa">
                        Xem chi tiết
                    </a>
                </div>
            </div>
        }
    </div>
</div>