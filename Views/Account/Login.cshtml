@model SPASMART.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-left">
            <small>SPASMART</small>
            <h1>Đăng nhập hệ thống</h1>
            <p>
                Admin và nhân viên đăng nhập để vào khu vực quản lý. Khách hàng chỉ cần đăng nhập khi đặt lịch.
            </p>
        </div>

        <div class="auth-form">
            <h2>Đăng nhập</h2>

            @if (TempData["NeedLogin"] != null)
            {
                <div class="alert alert-warning">
                    @TempData["NeedLogin"]
                </div>
            }

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <input asp-for="TenDangNhap" class="form-control" />
                    <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="MatKhau" type="password" class="form-control" />
                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-spa w-100">Đăng nhập</button>

                <div class="auth-link">
                    Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register">Đăng ký khách hàng</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}