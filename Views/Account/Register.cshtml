@model SPASMART.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-page">
    <div class="auth-card auth-card-wide">
        <div class="auth-left">
            <small>SPASMART</small>
            <h1>Tạo tài khoản khách hàng</h1>
            <p>
                Khách hàng cần tạo tài khoản trước khi đặt lịch sử dụng dịch vụ tại spa.
            </p>
        </div>

        <div class="auth-form">
            <h2>Đăng ký</h2>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="form-label">Họ tên</label>
                    <input asp-for="HoTenKhach" class="form-control" />
                    <span asp-validation-for="HoTenKhach" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input asp-for="SoDienThoaiKhach" class="form-control" />
                    <span asp-validation-for="SoDienThoaiKhach" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="EmailKhach" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Giới tính</label>
                    <select asp-for="GioiTinh" class="form-select">
                        <option value="">-- Chọn giới tính --</option>
                        <option value="Nữ">Nữ</option>
                        <option value="Nam">Nam</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Ngày sinh</label>
                    <input asp-for="NgaySinh" type="date" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Tên đăng nhập</label>
                    <input asp-for="TenDangNhap" class="form-control" />
                    <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Mật khẩu</label>
                    <input asp-for="MatKhau" type="password" class="form-control" />
                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-spa w-100">Đăng ký</button>

                <div class="auth-link">
                    Đã có tài khoản?
                    <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}