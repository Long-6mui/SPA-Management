@model SPASMART.Models.DichVuSanPham

@{
    ViewData["Title"] = "Thêm phụ liệu";
}

<div class="spa-form-page">
    <div class="spa-form-card">
        <h2>Thêm phụ liệu</h2>
        <p>Nhập thông tin mỹ phẩm, vật tư hoặc phụ liệu sử dụng trong spa.</p>

        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="Loai" value="Sản phẩm" />

            <div class="mb-3">
                <label class="form-label">Tên phụ liệu</label>
                <input asp-for="TenDVSP" class="form-control" />
                <span asp-validation-for="TenDVSP" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Mô tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Giá</label>
                    <input asp-for="Gia" class="form-control" />
                    <span asp-validation-for="Gia" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Đơn vị tính</label>
                    <input asp-for="DonViTinh" class="form-control" placeholder="Chai, hộp, cái..." />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Số lượng tồn</label>
                    <input asp-for="SoLuongTon" class="form-control" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Hạn sử dụng</label>
                    <input asp-for="HanSuDung" type="date" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Đường dẫn hình ảnh</label>
                <input asp-for="HinhAnh" class="form-control" placeholder="/images/sanpham/tinh-dau.jpg" />
            </div>

            <div class="mb-4">
                <label class="form-label">Trạng thái</label>
                <input asp-for="TrangThai" class="form-control" />
            </div>

            <button type="submit" class="btn-spa">Lưu phụ liệu</button>
            <a asp-action="Index" class="btn-light-spa">Quay lại</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}